# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to version control — it is listed in .gitignore.

# Required — PostgreSQL connection string (psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://tokensurf:changeme@localhost:5432/tokensurf

# Optional — server bind address and port (defaults shown).
HOST=0.0.0.0
PORT=8000
